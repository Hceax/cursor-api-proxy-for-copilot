# === Cursor CLI ===
# Path to Cursor CLI binary (default: agent)
# CURSOR_AGENT_BIN=agent

# Windows portable mode: bypass cmd.exe by invoking node.exe directly
# CURSOR_AGENT_NODE=C:\path\to\node.exe
# CURSOR_AGENT_SCRIPT=C:\path\to\index.js

# === Server ===
# CURSOR_BRIDGE_HOST=127.0.0.1
# CURSOR_BRIDGE_PORT=8765

# Protect the proxy with an API key
# CURSOR_BRIDGE_API_KEY=your-secret-key

# === Execution ===
# Default mode: ask | agent | plan
# CURSOR_BRIDGE_MODE=ask

# Default model when request doesn't specify one
# CURSOR_BRIDGE_DEFAULT_MODEL=auto

# Pass --force to Cursor CLI
# CURSOR_BRIDGE_FORCE=false

# Auto-approve MCP servers
# CURSOR_BRIDGE_APPROVE_MCPS=false

# Timeout per completion (ms)
# CURSOR_BRIDGE_TIMEOUT_MS=300000

# === Workspace ===
# Fallback workspace directory (default: cwd)
# CURSOR_BRIDGE_WORKSPACE=/path/to/your/project

# When true, CLI runs in an isolated temp dir (pure chat, can't touch project)
# CURSOR_BRIDGE_CHAT_ONLY_WORKSPACE=true

# === Session management ===
# Session idle timeout (ms, default: 30 min)
# CURSOR_BRIDGE_SESSION_TTL_MS=1800000

# Max conversation turns included in first message of a new session
# CURSOR_BRIDGE_MAX_HISTORY_TURNS=10

# === Logging ===
# Print full request/response content to stdout
# CURSOR_BRIDGE_VERBOSE=false

# Request log path
# CURSOR_BRIDGE_SESSIONS_LOG=~/.cursor-api-proxy/sessions.log

# === TLS (optional, for Tailscale/HTTPS) ===
# CURSOR_BRIDGE_TLS_CERT=/path/to/cert.pem
# CURSOR_BRIDGE_TLS_KEY=/path/to/key.pem
